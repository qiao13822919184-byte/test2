---
// 获取全局的基础路径 (线上是 /test/，本地也会自动适配)
const base = import.meta.env.BASE_URL;
---
<header style="background: #333; color: white; padding: 15px; text-align: center;">
  <nav>
    <!-- 首页链接：直接使用 base -->
    <a href={base} style="color: white; margin: 0 15px; text-decoration: none;">🏠 首页</a>
    
    <!-- 博客链接：在 base 后面拼上 blog -->
    <a href={`${base}blog`} style="color: white; margin: 0 15px; text-decoration: none;">✍️ 博客</a>
    <a href={`${base}information`} style="color: white; margin: 0 15px; text-decoration: none;">✍️ 关于我们</a>


  </nav>
</header>